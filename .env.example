# Copia a .env y ajusta. NUNCA subas .env al repo.
DJANGO_SECRET_KEY=dev-insecure-cambia-esto
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL
POSTGRES_DB=fairbet
POSTGRES_USER=fairbet
POSTGRES_PASSWORD=fairbet
DATABASE_URL=postgres://fairbet:fairbet@db:5432/fairbet

# Redis (un host; las DB se separan por indice en settings)
REDIS_HOST=redis
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
